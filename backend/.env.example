# Backend Environment Variables

# Gemini API for LLM and Embeddings
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase (PostgreSQL database)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Pinecone (Vector database)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=lecture-chunks

# CORS configuration (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Admin authentication for ingestion endpoints
SECRET_ADMIN_KEY=change_me_to_a_strong_random_string

# Optional: YouTube cookies for transcript fetching (helps avoid IP blocks)
# Set this to the path of a Netscape-format cookies.txt file
# Or place youtube_cookies.txt in the backend root folder
# YOUTUBE_COOKIES_FILE=/path/to/cookies.txt
